/**
 * Messages integration namespace.
 *
 * Wraps the Anthropic Messages API. The current cut covers the two
 * foundational calls; tool use, vision, prompt caching, and streaming
 * each warrant their own facet and will be added incrementally.
 *
 * Reference: https://github.com/anthropics/anthropic-sdk-python
 */
namespace anthropic.messages {

    /** Result of a single Messages API call. */
    schema MessageResult {
        text: String,
        model: String,
        stop_reason: String,
        input_tokens: Long,
        output_tokens: Long,
        cache_creation_input_tokens: Long,
        cache_read_input_tokens: Long
    }

    /** Token-count result for a prepared request. */
    schema TokenCount {
        input_tokens: Long,
        model: String
    }

    /**
     * Single-turn Messages call. Sends `prompt` as one user turn,
     * optionally with a `system` prompt, and returns the assistant's
     * text plus usage + stop reason.
     */
    event facet CreateMessage(
        prompt: String,
        system: String = "",
        model: String = "",
        max_tokens: Long = 1024,
        cache_system: Boolean = false) => (result: MessageResult)

    /**
     * Count input tokens for a prepared request before sending it.
     * Costs one accounting round-trip but no inference.
     */
    event facet CountTokens(
        prompt: String,
        system: String = "",
        model: String = "") => (count: TokenCount)

    /**
     * Convenience workflow: count tokens then generate text in one go.
     * Demonstrates composing the two facets and shows the input-budget
     * pattern the docs recommend before any large prompt.
     */
    workflow ChatOnce(prompt: String, system: String = "",
        model: String = "", max_tokens: Long = 1024) => (
            text: String,
            input_tokens: Long,
            output_tokens: Long) andThen {

        tokens = CountTokens(prompt = $.prompt,
            system = $.system,
            model = $.model)

        reply = CreateMessage(prompt = $.prompt,
            system = $.system,
            model = $.model,
            max_tokens = $.max_tokens)

        yield ChatOnce(
            text = reply.result.text,
            input_tokens = tokens.count.input_tokens,
            output_tokens = reply.result.output_tokens)
    }

    /** Result of a single tool-use round. */
    schema ToolUseResult {
        text: String,
        tool_uses_json: String,
        messages_json: String,
        stop_reason: String,
        model: String,
        input_tokens: Long,
        output_tokens: Long,
        cache_creation_input_tokens: Long,
        cache_read_input_tokens: Long
    }

    /**
     * Single round of a tool-use conversation.
     *
     * `tools_json` is a JSON-serialised list of tool definitions
     * (each is an object with name / description / input_schema,
     * matching the Anthropic SDK shape). `messages_json` may carry an
     * existing conversation history (JSON-serialised list of
     * {role, content}) — pass an empty string for the first round.
     *
     * The returned `tool_uses_json` is a JSON list of tool_use blocks
     * the model requested (each with id, name, input). The caller
     * executes each tool and threads results back via `messages_json`
     * on the next call. Multi-round loops live in handler / workflow
     * code (FFL has no `while`); for a turnkey Python loop, call
     * `run_tool_use_loop` on the Python side.
     */
    event facet CreateMessageWithTools(
        prompt: String = "",
        tools_json: String,
        messages_json: String = "",
        system: String = "",
        model: String = "",
        max_tokens: Long = 1024,
        cache_system: Boolean = false) => (result: ToolUseResult)

    /** Result of a vision call (one or more images plus a prompt). */
    schema VisionResult {
        text: String,
        model: String,
        stop_reason: String,
        image_count: Long,
        input_tokens: Long,
        output_tokens: Long,
        cache_creation_input_tokens: Long,
        cache_read_input_tokens: Long
    }

    /**
     * Single-turn vision call. Sends `prompt` together with one or
     * more images. `image_urls` and `image_paths` are
     * comma-separated lists — URLs go in as URL blocks, paths are
     * read from disk and sent as base64 blocks. At least one of the
     * two must be non-empty.
     */
    event facet CreateMessageWithImages(
        prompt: String,
        image_urls: String = "",
        image_paths: String = "",
        system: String = "",
        model: String = "",
        max_tokens: Long = 1024,
        cache_system: Boolean = false) => (result: VisionResult)

    /**
     * Result of a streaming Messages call. Same shape as MessageResult
     * with an extra `chunk_count` reporting how many text deltas were
     * emitted by the SSE stream.
     */
    schema StreamResult {
        text: String,
        model: String,
        stop_reason: String,
        chunk_count: Long,
        input_tokens: Long,
        output_tokens: Long,
        cache_creation_input_tokens: Long,
        cache_read_input_tokens: Long
    }

    /**
     * Streaming Messages call. The handler consumes the SSE stream
     * server-side and emits each text delta to the step log as it
     * arrives (so the dashboard shows progressive output), then
     * returns the final assembled text + usage. Use this when the
     * generation is long enough that per-token progress matters; for
     * one-shot prompts, `CreateMessage` is simpler.
     */
    event facet CreateMessageStream(
        prompt: String,
        system: String = "",
        model: String = "",
        max_tokens: Long = 1024,
        cache_system: Boolean = false) => (result: StreamResult)

    /** Result of a Messages call that references uploaded Files-API files. */
    schema FileMessageResult {
        text: String,
        model: String,
        stop_reason: String,
        file_count: Long,
        input_tokens: Long,
        output_tokens: Long,
        cache_creation_input_tokens: Long,
        cache_read_input_tokens: Long
    }

    /**
     * Single-turn Messages call that references uploaded Files-API
     * files as document or image content blocks — the RAG pattern.
     * Upload a PDF via `anthropic.files.UploadFile`, take its `id`,
     * and ask Claude questions about it here.
     *
     * `file_ids` is a comma-separated list of Anthropic file IDs.
     * `file_type` is `document` (PDFs, text — default) or `image`
     * (PNG/JPEG). All files in a single call share the same type.
     */
    event facet CreateMessageWithFile(
        prompt: String,
        file_ids: String,
        file_type: String = "document",
        system: String = "",
        model: String = "",
        max_tokens: Long = 1024,
        cache_system: Boolean = false) => (result: FileMessageResult)
}
