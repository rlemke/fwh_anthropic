/**
 * Message Batches API namespace.
 *
 * Submits many Messages requests as one batch (≈50% cheaper than
 * synchronous calls, 24-hour SLA). Three primitives are exposed —
 * compose your own polling cadence in the surrounding workflow.
 *
 * Reference: https://docs.anthropic.com/en/docs/build-with-claude/message-batches
 */
namespace anthropic.batch {

    /** Batch metadata returned by Submit + GetBatchStatus. */
    schema BatchMetadata {
        id: String,
        type: String,
        processing_status: String,
        created_at: String,
        expires_at: String,
        ended_at: String,
        results_url: String,
        processing: Long,
        succeeded: Long,
        errored: Long,
        canceled: Long,
        expired: Long
    }

    /** Aggregated batch results (results_json carries the per-request list). */
    schema BatchResults {
        batch_id: String,
        result_count: Long,
        results_json: String
    }

    /**
     * Submit a batch of Messages requests. `requests_json` is a
     * JSON-serialised list of objects shaped per the SDK's
     * MessageBatchRequest type (each has `custom_id` + `params`).
     */
    event facet SubmitBatch(
        requests_json: String) => (result: BatchMetadata) with Effect(kind = "external") with Cost(tier = "cheap")

    /** Check current status of a batch. Does NOT block on completion. */
    event facet GetBatchStatus(
        batch_id: String) => (result: BatchMetadata) with Effect(kind = "external") with Cost(tier = "cheap")

    /**
     * Pull results for an ended batch. `results_json` decodes to a
     * list of per-request dicts (with `custom_id`, `type`, and either
     * `text` + usage on success or `error_type` + `error_message` on
     * failure).
     */
    event facet GetBatchResults(
        batch_id: String) => (result: BatchResults) with Effect(kind = "external") with Cost(tier = "cheap")

    /**
     * Convenience: submit a batch, poll until ended, and pull results
     * in one workflow step. `poll_interval_seconds` and
     * `timeout_seconds` set the polling cadence and overall budget.
     * Use this when you don't need to drive the polling cadence
     * yourself; for fine-grained control, compose SubmitBatch +
     * GetBatchStatus + GetBatchResults in your own loop.
     */
    schema RunBatchResult {
        batch_id: String,
        processing_status: String,
        poll_count: Long,
        elapsed_seconds: Double,
        result_count: Long,
        results_json: String
    }

    event facet RunBatch(
        requests_json: String,
        poll_interval_seconds: Double = 10.0,
        timeout_seconds: Double = 600.0) => (result: RunBatchResult) with Effect(kind = "external") with Cost(tier = "expensive")
}
